{
  "info": {
    "name": "Coffee Platform API",
    "_postman_id": "coffee-platform-v1",
    "description": "Complete API collection for the Coffee Shop Pre-Order Platform.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "ownerToken", "value": "" },
    { "key": "ownerId", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "shopId", "value": "" },
    { "key": "menuItemId1", "value": "" },
    { "key": "menuItemId2", "value": "" },
    { "key": "queueId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "entryId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));",
                  "pm.collectionVariables.set('ownerToken', json.token);",
                  "pm.collectionVariables.set('ownerId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman-owner-{{$timestamp}}@demo.com\",\n  \"password\": \"password123\",\n  \"displayName\": \"Postman Owner\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/owner/register" }
          }
        },
        {
          "name": "Login Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));",
                  "pm.collectionVariables.set('ownerToken', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@chain.com\",\n  \"password\": \"password\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login" }
          }
        },
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));",
                  "pm.collectionVariables.set('customerToken', json.token);",
                  "pm.collectionVariables.set('customerId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"+1555{{$timestamp}}\",\n  \"name\": \"Postman Customer\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/customer/register" }
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));",
                  "pm.collectionVariables.set('customerToken', json.token);",
                  "pm.collectionVariables.set('customerId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"+6591110001\",\n  \"otp\": \"000000\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/customer/login" }
          }
        },
        {
          "name": "Get Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(json.id).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me" }
          }
        }
      ]
    },
    {
      "name": "Shop",
      "item": [
        {
          "name": "Create Shop",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has id', () => pm.expect(json.id).to.exist);",
                  "pm.collectionVariables.set('shopId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Coffee Lab\",\n  \"contactPhone\": \"+1234567890\",\n  \"contactEmail\": \"lab@coffee.com\",\n  \"addressLine\": \"1 Test Street\",\n  \"city\": \"Singapore\",\n  \"country\": \"SG\",\n  \"latitude\": 1.2841,\n  \"longitude\": 103.8511,\n  \"timezone\": \"Asia/Singapore\",\n  \"currency\": \"SGD\",\n  \"openingTime\": \"00:00\",\n  \"closingTime\": \"23:59\",\n  \"avgServiceSeconds\": 120\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/shops" }
          }
        },
        {
          "name": "List Shops",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/shops" }
          }
        },
        {
          "name": "Get Shop",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has name', () => pm.expect(pm.response.json().name).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/shops/{{shopId}}" }
          }
        },
        {
          "name": "Nearest Shops",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shops/nearest?lat=1.2841&lng=103.8511&radiusKm=10&limit=5"
            }
          }
        },
        {
          "name": "Add Menu Item 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('menuItemId1', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Flat White\",\n  \"description\": \"Double shot, silky milk\",\n  \"priceMinor\": 550\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/shops/{{shopId}}/menu-items" }
          }
        },
        {
          "name": "Add Menu Item 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('menuItemId2', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Croissant\",\n  \"description\": \"Butter croissant\",\n  \"priceMinor\": 400\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/shops/{{shopId}}/menu-items" }
          }
        },
        {
          "name": "List Menu Items",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/shops/{{shopId}}/menu-items" }
          }
        },
        {
          "name": "Add Queue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('queueId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Main Queue\",\n  \"maxSize\": 10\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/shops/{{shopId}}/queues" }
          }
        },
        {
          "name": "List Queues",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/shops/{{shopId}}/queues" }
          }
        },
        {
          "name": "Assign Operator",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{ownerId}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/shops/{{shopId}}/operators" }
          }
        }
      ]
    },
    {
      "name": "Order",
      "item": [
        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Status WAITING', () => pm.expect(json.status).to.eql('WAITING'));",
                  "pm.collectionVariables.set('orderId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopId\": {{shopId}},\n  \"items\": [\n    { \"menuItemId\": {{menuItemId1}}, \"quantity\": 1 },\n    { \"menuItemId\": {{menuItemId2}}, \"quantity\": 1 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/orders" }
          }
        },
        {
          "name": "Get Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has status', () => pm.expect(pm.response.json().status).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}" }
          }
        },
        {
          "name": "Queue Position",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has position', () => pm.expect(pm.response.json().position).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/queue-position" }
          }
        },
        {
          "name": "Cancel Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}" }
          }
        },
        {
          "name": "My Orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers/me/orders" }
          }
        }
      ]
    },
    {
      "name": "Queue Ops",
      "item": [
        {
          "name": "Queue Snapshot",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has queueId', () => pm.expect(pm.response.json().queueId).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/queues/{{queueId}}" }
          }
        },
        {
          "name": "Queue Entries",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "const entries = pm.response.json();",
                  "if (entries.length > 0) { pm.collectionVariables.set('entryId', entries[0].entryId); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/queues/{{queueId}}/entries" }
          }
        },
        {
          "name": "Serve Next",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status SERVED', () => pm.expect(pm.response.json().status).to.eql('SERVED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/queues/{{queueId}}/serve-next" }
          }
        },
        {
          "name": "Serve Specific",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status SERVED', () => pm.expect(pm.response.json().status).to.eql('SERVED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/queues/{{queueId}}/entries/{{entryId}}/serve" }
          }
        }
      ]
    }
  ]
}
